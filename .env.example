# ── Serveur ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # production en déploiement

# ── Base de données ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306                  # 8889 en local avec MAMP, 3306 sur O2switch
DB_USER=root
DB_PASSWORD=root
DB_NAME=rifline

# ── JWT (régénérer en prod : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ──
JWT_SECRET=change_me_jwt_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars

# ── SumUp (paiement) ─────────────────────────────────────
# Clé API au format sup_sk_... (dashboard developer.sumup.com → API keys).
# Pas de secret webhook : la confirmation de paiement se fait en rappelant
# l'API SumUp (GET /checkouts/{id}), authentifiée par cette clé.
SUMUP_API_KEY=sup_sk_XXXX     # clé sandbox en dev, clé production en prod
SUMUP_MERCHANT_CODE=          # code marchand (me.sumup.com → profil)

# ── URLs ─────────────────────────────────────────────────
# SERVER_URL sert aussi de base au return_url du webhook SumUp (POST serveur).
APP_URL=http://localhost:5173       # URL du frontend (CORS + redirect SumUp) — https://rif-line.com en prod
SERVER_URL=http://localhost:3000    # URL de l'API (images + webhook SumUp) — https://api.rif-line.com en prod

# ── Email (optionnel — laisser SMTP_HOST vide désactive les notifications) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RifLine <contact@rif-line.com>

# ── Frontend (Vite — préfixe VITE_, à mettre dans client/.env.production au build) ──
VITE_API_URL=http://localhost:3000/api   # https://api.rif-line.com/api en prod
