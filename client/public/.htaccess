# ── React Router (SPA) ───────────────────────────────────────────
# Toute URL qui ne correspond pas à un fichier/dossier réel est renvoyée
# vers index.html, qui laisse React Router gérer la route côté navigateur.
# Sans cette règle, recharger /catalogue, /checkout… retourne une 404 Apache.
Options -MultiViews
RewriteEngine On

# Ne pas réécrire les fichiers et dossiers qui existent réellement (assets, images…)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# ── Compression (gzip) ───────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ── Cache navigateur ─────────────────────────────────────────────
# Les assets buildés par Vite portent un hash dans leur nom (index-xxxx.js) :
# on peut les mettre en cache longue durée sans risque. index.html n'est jamais
# mis en cache pour que les nouveaux déploiements soient pris en compte immédiatement.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|webp|png|jpe?g|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
